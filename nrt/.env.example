# Kafka (19092 is the external/host port; containers use 9092 internally)
KAFKA_BOOTSTRAP_SERVERS=localhost:19092
KAFKA_GROUP_ID=nrt-mdm-consumer

# Postgres
POSTGRES_DSN=postgresql://mdm:mdm@localhost:5432/mdm

# Topics
KAFKA_TOPICS_CRM_A=topic.crm.a
KAFKA_TOPICS_CRM_B=topic.crm.b
KAFKA_TOPICS_CRM_C=topic.crm.c
KAFKA_TOPIC_GOLDEN=topic.mdm.golden
KAFKA_TOPIC_XREF=topic.mdm.xref
KAFKA_TOPIC_DLQ=topic.mdm.dlq
